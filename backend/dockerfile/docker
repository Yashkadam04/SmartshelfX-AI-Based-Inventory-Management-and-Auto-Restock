# ═══════════════════════════════════════════════════════════════
#  SmartShelfX — Backend Dockerfile
#  This file tells Docker HOW to build our Node.js app container
# ═══════════════════════════════════════════════════════════════

# ── STAGE 1: Install Dependencies ───────────────────────────────
# We use multi-stage build — this means we build in one container
# and run in another (smaller, cleaner) container
# Think of it as: "use a big kitchen to cook, but serve on a small plate"

FROM node:18-alpine AS builder
# FROM   = start with this base image (node 18 on Alpine Linux)
# alpine = very small Linux (5MB vs 900MB for full Ubuntu)
# AS builder = name this stage "builder"

WORKDIR /app
# WORKDIR = set working directory inside container
# All commands from here run inside /app folder

COPY package*.json ./
# COPY package.json and package-lock.json first
# WHY FIRST? Docker caches layers. If code changes but package.json
# doesn't change, Docker skips npm install (saves time!)

RUN npm ci --only=production
# npm ci = clean install (faster and more reliable than npm install)
# --only=production = skip devDependencies (no nodemon etc.)

# ── STAGE 2: Production Container ───────────────────────────────
FROM node:18-alpine AS production
# Start fresh with clean small image

# Create a non-root user for security
# NEVER run apps as root in containers (security best practice)
RUN addgroup -g 1001 -S nodejs && \
    adduser  -S appuser -u 1001 -G nodejs

WORKDIR /app

# Copy node_modules from builder stage (already installed)
COPY --from=builder /app/node_modules ./node_modules

# Copy our source code
COPY . .

# Give ownership to our non-root user
RUN chown -R appuser:nodejs /app

# Switch to non-root user
USER appuser

# Tell Docker our app listens on port 3000
EXPOSE 3000

# Health check — Docker uses this to know if container is healthy
# If /api/health returns error, Docker will restart the container
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
  CMD wget -qO- http://localhost:3000/api/health || exit 1

# The command that starts our app
CMD ["node", "server.js"]
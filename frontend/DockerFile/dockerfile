# ═══════════════════════════════════════════════════════════════
#  SmartShelfX — Frontend Dockerfile
#  Build Angular app, then serve with Nginx
# ═══════════════════════════════════════════════════════════════

# ── STAGE 1: Build Angular App ───────────────────────────────────
FROM node:18-alpine AS builder

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm ci

# Copy source code
COPY . .

# Build Angular for production
# This creates optimized JS/CSS files in dist/ folder
RUN npx ng build --configuration production

# ── STAGE 2: Serve with Nginx ─────────────────────────────────────
# Nginx is a web server — perfect for serving static HTML/JS/CSS files
# The Angular build output IS static files — so Nginx serves them perfectly
FROM nginx:alpine AS production

# Remove default nginx page
RUN rm -rf /usr/share/nginx/html/*

# Copy our Angular build output into Nginx's serve folder
COPY --from=builder /app/dist/smartshelfx/browser /usr/share/nginx/html

# Copy our Nginx config
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
  CMD wget -qO- http://localhost:80 || exit 1

CMD ["nginx", "-g", "daemon off;"]